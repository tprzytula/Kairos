{
  "name": "kairos",
  "version": "1.0.0",
  "description": "Kairos is a platform for helping you manage your time.",
  "author": "Tomasz Przytula",
  "license": "AGPL-3.0",
  "scripts": {
    "build": "yarn build:web && yarn build:lambdas",
    "build:web": "cd packages/web && yarn && yarn build",
    "build:lambdas": "cd packages/lambdas && yarn && yarn build",
    "test": "concurrently --kill-others-on-fail \"yarn test:web\" \"yarn test:lambdas\"",
    "test:web": "cd packages/web && yarn test",
    "test:lambdas": "cd packages/lambdas && yarn test",
    "lint": "yarn lint:web && yarn lint:lambdas",
    "lint:web": "cd packages/web && yarn lint",
    "lint:lambdas": "cd packages/lambdas && yarn lint",
    "prettier": "prettier . --check"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "prettier": "^3.5.3"
  }
}
