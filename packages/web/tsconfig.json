{
  "compilerOptions": {
    "incremental": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strict": true,
    "moduleResolution": "bundler",
    "target": "ES2020",
    "module": "ESNext",
    "isolatedModules": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom", "vitest-fetch-mock"]
  },
  "include": ["src"],
  "exclude": ["src/sw.ts"]
}
