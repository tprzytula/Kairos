  "scripts": {
    "start": "parcel src/index.html",
    "build": "yarn build:app && yarn build:sw && yarn inject:version",
    "build:app": "parcel build src/index.html",
    "build:sw": "parcel build src/sw.ts --dist-dir dist --public-url /",
    "inject:version": "node scripts/inject-version.js",
    "dev": "yarn dev:app",
    "dev:app": "parcel src/index.html",
    "lint": "oxlint src",
    "prettier": "prettier src --check",
    "prettier:fix": "yarn prettier -- --write",
    "test": "bash run-tests.sh",
    "test:single": "bun test"
  },
  "dependencies": {
    "@date-io/date-fns": "^3.2.1",
