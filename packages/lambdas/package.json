{
  "private": true,
  "workspaces": [
    "sources/*",
    "libs/*"
  ],
  "scripts": {
    "build": "yarn bundle && yarn package",
    "bundle": "rm -rf dist && esbuild ./sources/* --entry-names=[dir]/[name]/index --bundle --minify --sourcemap --platform=node --target=node20 --outdir=dist",
    "package": "cd dist && for f in * ; do ([ -d \"$f\" ] && cd $f && zip $f.zip *) ; done",
    "lint": "oxlint sources libs --ignore-pattern='dist/**' --ignore-pattern='libs/types/generated/**'",
    "prettier": "prettier . --write",
    "test": "jest --silent",
    "test:watch": "jest --watch --silent"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "esbuild": "^0.25.2",
    "lerna": "^8.2.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@swc/core": "^1.10.0",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.14",
    "@types/web-push": "^3.6.4",
    "aws-sdk": "^2.1692.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.0",
    "oxlint": "^1.51.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier . --write"
    ]
  }
}
