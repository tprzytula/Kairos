{
  "private": true,
  "workspaces": [
    "sources/*",
    "libs/*"
  ],
  "scripts": {
    "build": "yarn bundle && yarn package",
    "bundle": "rm -rf dist && esbuild ./sources/* --entry-names=[dir]/[name]/index --bundle --minify --sourcemap --platform=node --target=node20 --outdir=dist",
    "package": "cd dist && for f in * ; do ([ -d \"$f\" ] && cd $f && zip $f.zip *) ; done",
    "lint": "oxlint sources libs --ignore-pattern='dist/**' --ignore-pattern='libs/types/generated/**'",
    "prettier": "prettier . --write",
    "test": "vitest run --silent",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kairos/shared": "file:../shared",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-sns": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "esbuild": "^0.25.2",
    "lerna": "^8.2.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.2",
    "aws-sdk": "^2.1692.0",
    "lint-staged": "^15.5.0",
    "oxlint": "1.51.0",
    "prettier": "^3.5.3",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier . --write"
    ]
  }
}
