{
  "private": true,
  "workspaces": [
    "sources/*",
    "libs/*"
  ],
  "scripts": {
    "build": "yarn bundle && yarn package",
    "bundle": "rm -rf dist && bun build ./sources/*/index.ts --outdir=dist --target=node --minify --sourcemap=external --root=./sources",
    "package": "cd dist && for f in * ; do ([ -d \"$f\" ] && cd $f && zip $f.zip *) ; done",
    "lint": "oxlint sources libs --ignore-pattern='dist/**' --ignore-pattern='libs/types/generated/**'",
    "prettier": "prettier . --write",
    "test": "bash run-tests.sh",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "lerna": "^8.2.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4",
    "aws-sdk": "^2.1692.0",
    "lint-staged": "^15.5.0",
    "oxlint": "^1.51.0",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier . --write"
    ]
  }
}
